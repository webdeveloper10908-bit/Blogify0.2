<nav class="navbar navbar-expand-lg bg-dark fixed-top" data-bs-theme="dark">
  <div class="container-fluid">
    <a class="navbar-brand" href="/">Blogify</a>
    
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavDropdown">
      <!-- Left side links -->
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <a class="nav-link" aria-current="page" href="/">Home</a>
        </li>
        <% if (locals.user) { %>
          <li class="nav-item">
            <a class="nav-link" href="/blogs/add-new">Add Blog</a>
          </li>
        <% } %>
      </ul>

      <!-- Right side links -->
      <ul class="navbar-nav ms-auto align-items-center">
        <% if (locals.user) { %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <img 
                src="<%= locals.user.profileImageURL || '/imgs/default.png' %>" 
                alt="<%= locals.user.fullName %>" 
                width="32" 
                height="32" 
                class="rounded-circle border border-light" 
                style="object-fit: cover;"
                onerror="this.src='/imgs/default.png';">
              <span><%= locals.user.fullName %></span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/user/profile">👤 View Profile</a></li>
              <li><a class="dropdown-item" href="#">Settings</a></li>
              <% if (locals.user.role === "ADMIN") { %>
                <li><a class="dropdown-item" href="/admin/users">🔧 Admin Panel</a></li>
              <% } %>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item text-danger" href="/user/logout">Logout</a></li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/user/signup">Create Account</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/user/signin">Sign In</a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<% if (locals.error) { %>
  <div class="container mt-5"> 
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <%= locals.error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  </div>
<% } %>
