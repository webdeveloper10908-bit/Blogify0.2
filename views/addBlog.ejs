<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Add New Blog | Blogify</title>
</head>
<body>
    <%- include("./partials/nave") %>

    <div class="container mt-5" style="max-width: 700px;">
        <h2 class="mb-4">✍️ Write New Blog</h2>

        <% if (locals.error) { %>
            <div class="alert alert-danger"><%= locals.error %></div>
        <% } %>

        <form action="/blogs/add-new" method="POST" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label">Blog Title</label>
                <input type="text" name="title" class="form-control" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Cover Image</label>
                <input type="file" name="coverImage" class="form-control" accept="image/*">
                <small class="text-muted">Optional (JPG, PNG, etc.)</small>
            </div>

            <div class="mb-3">
                <label class="form-label">Blog Content</label>
                <textarea name="body" rows="15" class="form-control" required></textarea>
            </div>

            <button type="submit" class="btn btn-primary btn-lg">Publish Blog</button>
        </form>
    </div>

    <%- include("./partials/scripts") %>
</body>
</html>
