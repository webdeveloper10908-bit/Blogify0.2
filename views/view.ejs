<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title><%= blog.title %> | Blogify</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
    
    <style>
        .blog-content {
            font-size: 1.1rem;
            line-height: 1.9;
        }
        .blog-content h2 {
            margin-top: 2rem;
            margin-bottom: 1rem;
            font-weight: 700;
        }
        .blog-content p {
            margin-bottom: 1.5rem;
        }
        .blog-content pre {
            position: relative;
            background: #1e1e1e;
            border-radius: 10px;
            padding: 1.2rem;
            overflow-x: auto;
            margin: 1.8rem 0;
        }
        .blog-content code {
            font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        }
        .copy-btn {
            position: absolute;
            top: 12px;
            right: 12px;
            background: rgba(255,255,255,0.15);
            color: #fff;
            border: none;
            padding: 6px 14px;
            border-radius: 6px;
            font-size: 0.85rem;
            cursor: pointer;
        }
        .copy-btn:hover {
            background: #0d6efd;
        }
        .blog-content img {
            max-width: 100%;
            height: auto;
            margin: 2rem 0;
            border-radius: 8px;
        }
        .sidebar-widget {
            position: sticky;
            top: 100px;
        }
    </style>
</head>
<body>
    <%- include("./partials/nave") %>

    <article class="container my-5">
        <div class="row">
            <!-- Main Content -->
            <div class="col-lg-8">
                <a href="/" class="btn btn-outline-primary btn-sm mb-4">
                    <i class="fas fa-arrow-left"></i> Back to Home
                </a>

                <div class="mb-5">
                    <h1 class="display-5 fw-bold mb-3"><%= blog.title %></h1>
                    <div class="d-flex align-items-center justify-content-between py-3 border-top border-bottom">
                        <div class="d-flex align-items-center gap-3">
                            <img src="<%= blog.createdBy.profileImageURL %>" 
                                 alt="<%= blog.createdBy.fullName %>" 
                                 width="48" height="48" 
                                 class="rounded-circle"
                                 onerror="this.src='/imgs/default.png';">
                            <div>
                                <a href="#" class="fw-bold text-decoration-none"><%= blog.createdBy.fullName %></a>
                                <div class="small text-muted">
                                    <%= formatDate(blog.createdAt) %> 
                                    <% if (blog.readingTime) { %>• <%= blog.readingTime %> min read<% } %>
                                </div>
                            </div>
                        </div>

                        <% if (locals.user && locals.user._id == blog.createdBy._id) { %>
                            <div class="d-flex gap-2">
                                <a href="/blogs/<%= blog._id %>/edit" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <button class="btn btn-outline-danger btn-sm" onclick="deleteBlog('<%= blog._id %>')">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </div>
                        <% } %>
                    </div>
                </div>

                <% if (blog.coverImageURL) { %>
                    <img src="<%= blog.coverImageURL %>" 
                         alt="<%= blog.title %>" 
                         class="img-fluid rounded-3 mb-5 shadow-sm">
                <% } %>

                <div class="blog-content mb-5" id="blogContent">
                    <%- blog.body %>
                </div>

                <% if (blog.tags && blog.tags.length > 0) { %>
                    <div class="mb-5 pb-4 border-bottom">
                        <h6 class="fw-bold mb-3">Tags</h6>
                        <% blog.tags.forEach(tag => { %>
                            <a href="/blogs/tags/<%= tag %>" class="btn btn-sm btn-outline-primary me-2 mb-2">#<%= tag %></a>
                        <% }) %>
                    </div>
                <% } %>

                <div class="d-flex gap-3 py-4 border-top border-bottom">
                    <button class="btn btn-outline-danger" id="likeBtn" onclick="toggleLike()">
                        <i class="fas fa-heart <%= hasLiked ? 'fas' : 'far' %>"></i>
                        <span id="likeCount"><%= blog.likes ? blog.likes.length : 0 %></span> Like
                    </button>
                    <button class="btn btn-outline-primary" id="shareBtn">
                        <i class="fas fa-share-alt"></i> Share
                    </button>
                </div>

                <div class="mt-5">
                    <h4 class="fw-bold mb-4"><i class="fas fa-comments"></i> Comments</h4>
                    <% if (locals.user) { %>
                        <div class="card mb-4">
                            <div class="card-body">
                                <form id="commentForm">
                                    <textarea class="form-control mb-3" id="commentContent" rows="3" placeholder="Share your thoughts..." required></textarea>
                                    <button type="submit" class="btn btn-primary">Post Comment</button>
                                </form>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="alert alert-info">Sign in to leave a comment</div>
                    <% } %>
                    <div id="commentsList"></div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4 mt-5 mt-lg-0">
                <!-- Author Info -->
                <div class="card shadow-sm sidebar-widget mb-4">
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <img src="<%= blog.createdBy.profileImageURL %>" width="80" height="80" class="rounded-circle mb-3" onerror="this.src='/imgs/default.png';">
                            <h5 class="fw-bold"><%= blog.createdBy.fullName %></h5>
                            <p class="text-muted small mb-3"><%= blog.createdBy.bio || 'Blogger' %></p>
                        </div>
                        <% if (locals.user && locals.user._id != blog.createdBy._id) { %>
                            <button class="btn btn-primary w-100" id="followBtn" onclick="toggleFollow()">Follow</button>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </article>

    <%- include("./partials/scripts") %>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script>
        hljs.highlightAll();

        function addCopyButtons() {
            document.querySelectorAll('#blogContent pre').forEach(pre => {
                if (pre.querySelector('.copy-btn')) return;
                const btn = document.createElement('button');
                btn.className = 'copy-btn';
                btn.innerHTML = '<i class="fas fa-copy"></i> Copy';
                btn.addEventListener('click', () => {
                    const code = pre.querySelector('code').textContent;
                    navigator.clipboard.writeText(code).then(() => {
                        btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
                        setTimeout(() => btn.innerHTML = '<i class="fas fa-copy"></i> Copy', 2000);
                    });
                });
                pre.appendChild(btn);
            });
        }

        window.addEventListener('load', addCopyButtons);
    </script>

    <script>
        const blogId = '<%= blog._id %>';
        const currentUserId = '<%= locals.user ? locals.user._id : "" %>';

        async function toggleLike() {
            if (!currentUserId) return window.location.href = '/user/signin';
            try {
                const res = await axios.post(`/blogs/${blogId}/like`);
                const data = res.data;
                if (data.success) {
                    const likeCount = document.getElementById('likeCount');
                    likeCount.textContent = data.likeCount;
                }
            } catch (err) {}
        }

        loadComments();
    </script>
</body>
</html>
