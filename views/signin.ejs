<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account - Blogify</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .signup-container {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            width: 100%;
            max-width: 450px;
            animation: slideIn 0.5s ease-out;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        h2 {
            text-align: center;
            margin-bottom: 30px;
            color: #333;
            font-size: 28px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: #555;
            font-weight: 500;
            font-size: 14px;
        }

        input[type="text"],
        input[type="email"],
        input[type="password"] {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 16px;
            transition: border-color 0.3s;
        }

        input[type="text"]:focus,
        input[type="email"]:focus,
        input[type="password"]:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 5px rgba(102, 126, 234, 0.3);
        }

        .otp-section {
            margin: 25px 0;
            padding: 20px;
            background: #f8f9fa;
            border-radius: 8px;
            display: none;
        }

        .otp-section.show {
            display: block;
            animation: slideIn 0.5s ease-out;
        }

        .otp-section label {
            text-align: center;
            margin-bottom: 15px;
            color: #333;
            font-size: 16px;
        }

        .otp-container {
            display: flex;
            gap: 8px;
            justify-content: center;
            margin: 15px 0;
            flex-wrap: wrap;
        }

        .otp-box {
            width: 50px;
            height: 50px;
            text-align: center;
            font-size: 24px;
            font-weight: bold;
            border: 2px solid #ddd;
            border-radius: 8px;
            transition: all 0.3s;
        }

        .otp-box:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 5px rgba(102, 126, 234, 0.3);
        }

        .button-group {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        button {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 10px;
        }

        .btn-send-otp {
            background: #667eea;
            color: white;
        }

        .btn-send-otp:hover:not(:disabled) {
            background: #5568d3;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .btn-create {
            background: #28a745;
            color: white;
            display: none;
        }

        .btn-create.show {
            display: block;
        }

        .btn-create:hover:not(:disabled) {
            background: #218838;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(40, 167, 69, 0.4);
        }

        button:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .message {
            text-align: center;
            margin-top: 15px;
            min-height: 24px;
            font-weight: 500;
            padding: 10px;
            border-radius: 6px;
            font-size: 14px;
        }

        .message.error {
            color: #dc3545;
            background: #f8d7da;
            border: 1px solid #f5c6cb;
        }

        .message.success {
            color: #155724;
            background: #d4edda;
            border: 1px solid #c3e6cb;
        }

        .footer {
            text-align: center;
            margin-top: 20px;
            color: #666;
            font-size: 14px;
        }

        .footer a {
            color: #667eea;
            text-decoration: none;
            font-weight: 600;
        }

        .footer a:hover {
            text-decoration: underline;
        }

        .progress-steps {
            display: flex;
            justify-content: space-between;
            margin-bottom: 30px;
            font-size: 12px;
            color: #999;
        }

        .step {
            text-align: center;
        }

        .step.active {
            color: #667eea;
            font-weight: bold;
        }

        .timer {
            text-align: center;
            color: #667eea;
            font-size: 12px;
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <div class="signup-container">
        <h2>🚀 Blogify</h2>

        <div class="progress-steps">
            <div class="step active" id="step1">1. Details</div>
            <div class="step" id="step2">2. Verify OTP</div>
            <div class="step" id="step3">3. Done</div>
        </div>

        <form id="signupForm">
            <div class="form-group">
                <label for="fullName">Full Name</label>
                <input type="text" id="fullName" placeholder="John Doe" required>
            </div>

            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" placeholder="your@email.com" required>
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" placeholder="At least 6 characters" minlength="6" required>
            </div>

            <button type="button" id="sendOtpBtn" class="btn-send-otp">Send OTP to Email</button>

            <div class="otp-section" id="otpSection">
                <label>Enter 6-Digit OTP</label>
                <p style="text-align: center; color: #666; font-size: 12px; margin-bottom: 10px;">
                    Check your email for the OTP code
                </p>
                <div class="otp-container" id="otpContainer">
                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" required>
                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" required>
                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" required>
                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" required>
                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" required>
                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" required>
                </div>
                <div class="timer" id="timer"></div>
                <button type="submit" class="btn-create show">✓ Create Account</button>
            </div>
        </form>

        <div id="message" class="message"></div>

        <div class="footer">
            <p>Already have an account? <a href="/user/signup">Sign In Here</a></p>
        </div>
    </div>

    <script>
        const otpBoxes = document.querySelectorAll('.otp-box');
        const sendOtpBtn = document.getElementById('sendOtpBtn');
        const messageDiv = document.getElementById('message');
        const otpSection = document.getElementById('otpSection');
        const timerDiv = document.getElementById('timer');
        const step1 = document.getElementById('step1');
        const step2 = document.getElementById('step2');
        const step3 = document.getElementById('step3');
        let resendTimer = 0;

        // OTP Auto Focus and only numbers
        otpBoxes.forEach((box, i) => {
            box.addEventListener('input', (e) => {
                e.target.value = e.target.value.replace(/[^0-9]/g, '');
                if (e.target.value.length === 1 && i < 5) {
                    otpBoxes[i + 1].focus();
                }
            });

            box.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && i > 0 && !box.value) {
                    otpBoxes[i - 1].focus();
                }
            });
        });

        function showMessage(msg, type = "error") {
            messageDiv.textContent = msg;
            messageDiv.className = `message ${type}`;
        }

        function updateTimer() {
            if (resendTimer > 0) {
                timerDiv.textContent = `Resend OTP in ${resendTimer}s`;
                resendTimer--;
                setTimeout(updateTimer, 1000);
            } else {
                timerDiv.textContent = '';
            }
        }

        // Send OTP
        sendOtpBtn.addEventListener('click', async () => {
            const fullName = document.getElementById('fullName').value.trim();
            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;

            if (!fullName || !email || !password) {
                showMessage("❌ All fields are required!", "error");
                return;
            }

            if (password.length < 6) {
                showMessage("❌ Password must be at least 6 characters", "error");
                return;
            }

            sendOtpBtn.disabled = true;
            sendOtpBtn.textContent = "Sending OTP...";
            messageDiv.innerHTML = '';

            try {
                const res = await fetch('/user/send-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fullName, email, password })
                });

                const data = await res.json();

                if (!res.ok || !data.success) {
                    showMessage(`❌ ${data.message || "Failed to send OTP"}`, "error");
                    sendOtpBtn.disabled = false;
                    sendOtpBtn.textContent = "Send OTP to Email";
                    return;
                }

                showMessage("✅ OTP sent to your email! Check your inbox.", "success");

                // Show OTP section
                otpSection.classList.add('show');
                step1.classList.remove('active');
                step2.classList.add('active');

                // Clear OTP boxes
                otpBoxes.forEach(box => box.value = '');
                otpBoxes[0].focus();

                // Resend timer
                resendTimer = 60;
                updateTimer();

                // Disable button for cooldown
                sendOtpBtn.disabled = true;
                setTimeout(() => {
                    sendOtpBtn.disabled = false;
                    sendOtpBtn.textContent = "Send OTP to Email";
                }, 60000);

            } catch (err) {
                console.error('Error:', err);
                showMessage(`❌ Server error: ${err.message}`, "error");
                sendOtpBtn.disabled = false;
                sendOtpBtn.textContent = "Send OTP to Email";
            }
        });

        // Verify OTP & Create Account
        document.getElementById('signupForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            let otpValue = '';
            otpBoxes.forEach(box => otpValue += box.value);

            if (otpValue.length !== 6) {
                showMessage("❌ Please enter the complete 6-digit OTP", "error");
                return;
            }

            const submitBtn = document.querySelector('.btn-create');
            submitBtn.disabled = true;
            submitBtn.textContent = "Creating Account...";

            try {
                const email = document.getElementById('email').value.trim();

                const res = await fetch('/user/signin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, otp: otpValue })
                });

                const data = await res.json();

                if (res.ok && data.success) {
                    showMessage("✅ Account created successfully! Redirecting...", "success");
                    step2.classList.remove('active');
                    step3.classList.add('active');

                    setTimeout(() => {
                        window.location.href = "/user/signup";
                    }, 1500);
                } else {
                    showMessage(`❌ ${data.message || "Invalid OTP"}`, "error");
                    submitBtn.disabled = false;
                    submitBtn.textContent = "✓ Create Account";
                }
            } catch (err) {
                console.error('Error:', err);
                showMessage(`❌ Verification failed: ${err.message}`, "error");
                submitBtn.disabled = false;
                submitBtn.textContent = "✓ Create Account";
            }
        });
    </script>
</body>
</html>
