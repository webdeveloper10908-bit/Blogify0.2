<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title><%= user.fullName %> - Profile | Blogify</title>
</head>
<body>
    <%- include("./partials/nave") %>

    <!-- Profile Header -->
    <header class="bg-primary-soft border-bottom py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-auto text-center mb-4 mb-md-0">
                    <img src="<%= user.profileImageURL || '/imgs/default.png' %>" 
                         alt="<%= user.fullName %>" 
                         width="120" height="120" 
                         class="rounded-circle border border-4 shadow-sm mb-3"
                         style="object-fit: cover;"
                         onerror="this.src='/imgs/default.png';">
                </div>

                <div class="col-md flex-grow-1">
                    <h1 class="fw-bold mb-2"><%= user.fullName %></h1>
                    <p class="text-muted mb-3"><%= user.email %></p>
                    <% if (user.bio) { %>
                        <p class="mb-3"><%= user.bio %></p>
                    <% } %>
                    <% if (user.website) { %>
                        <p class="mb-3">
                            <a href="<%= user.website %>" target="_blank" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-globe"></i> Visit Website
                            </a>
                        </p>
                    <% } %>
                    
                    <!-- Stats -->
                    <div class="d-flex gap-4">
                        <div>
                            <h5 class="fw-bold"><%= blogs ? blogs.length : 0 %></h5>
                            <small class="text-muted">Blogs</small>
                        </div>
                        <div>
                            <h5 class="fw-bold"><%= user.followers ? user.followers.length : 0 %></h5>
                            <small class="text-muted">Followers</small>
                        </div>
                        <div>
                            <h5 class="fw-bold"><%= user.following ? user.following.length : 0 %></h5>
                            <small class="text-muted">Following</small>
                        </div>
                    </div>
                </div>

                <div class="col-md-auto">
                    <div class="d-flex gap-2">
                        <% if (isOwnProfile) { %>
                            <!-- Edit Profile Button (Only for own profile) -->
                            <button class="btn btn-primary" id="editProfileBtn">
                                <i class="fas fa-edit"></i> Edit Profile
                            </button>
                        <% } else { %>
                            <!-- Follow Button (For other users' profiles) -->
                            <% if (currentUserId) { %>
                                <button class="btn btn-outline-primary" id="followBtn" 
                                        onclick="toggleFollow('<%= user._id %>', this)"
                                        data-following="<%= isFollowing %>">
                                    <i class="fas <%= isFollowing ? 'fa-user-check' : 'fa-user-plus' %>"></i>
                                    <%= isFollowing ? 'Following' : 'Follow' %>
                                </button>
                            <% } else { %>
                                <a href="/user/signin" class="btn btn-primary">
                                    <i class="fas fa-user-plus"></i> Sign In to Follow
                                </a>
                            <% } %>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Navigation Tabs -->
    <div class="container my-4">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="blogs-tab" data-bs-toggle="tab" 
                        data-bs-target="#blogs" type="button" role="tab" aria-selected="true">
                    <i class="fas fa-book"></i> Blogs
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="followers-tab" data-bs-toggle="tab" 
                        data-bs-target="#followers" type="button" role="tab" aria-selected="false">
                    <i class="fas fa-users"></i> Followers
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="following-tab" data-bs-toggle="tab" 
                        data-bs-target="#following" type="button" role="tab" aria-selected="false">
                    <i class="fas fa-heart"></i> Following
                </button>
            </li>
            <% if (isOwnProfile) { %>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="analytics-tab" data-bs-toggle="tab" 
                            data-bs-target="#analytics" type="button" role="tab" aria-selected="false">
                        <i class="fas fa-chart-line"></i> Analytics
                    </button>
                </li>
            <% } %>
        </ul>
    </div>

    <!-- Tab Content -->
    <div class="container mb-5">
        <div class="tab-content">
            <!-- Blogs Tab -->
            <div class="tab-pane fade show active" id="blogs" role="tabpanel">
                <% if (typeof blogs !== 'undefined' && blogs.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="fas fa-inbox fa-5x text-muted mb-3"></i>
                        <h4 class="text-muted">No blogs published yet</h4>
                        <% if (isOwnProfile) { %>
                            <a href="/blogs/add-new" class="btn btn-primary mt-3">
                                <i class="fas fa-pen"></i> Write First Blog
                            </a>
                        <% } %>
                    </div>
                <% } else { %>
                    <div class="row">
                        <% blogs.forEach(blog => { %>
                            <div class="col-lg-6 col-xl-6 mb-4">
                                <div class="card blog-card h-100">
                                    <div class="position-relative">
                                        <% if (blog.coverImageURL) { %>
                                            <img src="<%= blog.coverImageURL %>" 
                                                 class="card-img-top blog-card-image" 
                                                 alt="<%= blog.title %>"
                                                 onerror="this.src='/images/default-blog.png';">
                                        <% } else { %>
                                            <div class="bg-light d-flex align-items-center justify-content-center blog-card-image">
                                                <i class="fas fa-image fa-3x text-muted"></i>
                                            </div>
                                        <% } %>

                                        <div class="position-absolute top-0 end-0 m-2">
                                            <% if (blog.status === 'draft') { %>
                                                <span class="badge bg-warning text-dark">Draft</span>
                                            <% } else if (blog.isFeatured) { %>
                                                <span class="badge bg-success">Featured</span>
                                            <% } %>
                                        </div>

                                        <% if (isOwnProfile) { %>
                                            <div class="dropdown position-absolute top-0 start-0 m-2">
                                                <button class="btn btn-sm btn-dark dropdown-toggle" data-bs-toggle="dropdown">
                                                    <i class="fas fa-ellipsis-v"></i>
                                                </button>
                                                <ul class="dropdown-menu">
                                                    <li><a class="dropdown-item" href="/blogs/<%= blog._id %>"><i class="fas fa-eye"></i> View</a></li>
                                                    <li><a class="dropdown-item" href="/blogs/<%= blog._id %>/edit"><i class="fas fa-edit"></i> Edit</a></li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <a class="dropdown-item text-danger" 
                                                           href="#" 
                                                           onclick="deleteBlog('<%= blog._id %>', event)">
                                                           <i class="fas fa-trash"></i> Delete
                                                        </a>
                                                    </li>
                                                </ul>
                                            </div>
                                        <% } %>
                                    </div>

                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title fw-bold">
                                            <%= truncate(blog.title, 60) %>
                                        </h5>

                                        <!-- Tags -->
                                        <% if (blog.tags && blog.tags.length > 0) { %>
                                            <div class="mb-2">
                                                <% blog.tags.slice(0, 2).forEach(tag => { %>
                                                    <span class="badge bg-primary-soft text-primary me-1">
                                                        <%= tag %>
                                                    </span>
                                                <% }) %>
                                            </div>
                                        <% } %>

                                        <p class="card-text text-muted flex-grow-1">
                                            <%= truncate(blog.excerpt || (blog.body ? blog.body.substring(0, 100) : ''), 80) %>
                                        </p>

                                        <!-- Blog Stats -->
                                        <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                                            <small class="text-muted">
                                                <i class="fas fa-calendar"></i> 
                                                <%= formatDate(blog.createdAt).split(',')[0] %>
                                            </small>
                                            <div>
                                                <small class="text-muted me-3">
                                                    <i class="fas fa-eye"></i> <%= blog.viewCount || 0 %>
                                                </small>
                                                <small class="text-muted">
                                                    <i class="fas fa-heart"></i> <%= blog.likes ? blog.likes.length : 0 %>
                                                </small>
                                            </div>
                                        </div>

                                        <a href="/blogs/<%= blog._id %>" class="btn btn-primary btn-sm mt-3">
                                            <i class="fas fa-arrow-right"></i> Read
                                        </a>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>

            <!-- Followers Tab -->
            <div class="tab-pane fade" id="followers" role="tabpanel">
                <% if (user.followers && user.followers.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="fas fa-user-friends fa-5x text-muted mb-3"></i>
                        <p class="text-muted">No followers yet</p>
                    </div>
                <% } else { %>
                    <div class="row">
                        <% if (user.followers) { %>
                            <% user.followers.forEach(follower => { %>
                                <div class="col-md-6 col-lg-4 mb-3">
                                    <div class="card">
                                        <div class="card-body text-center">
                                            <img src="<%= follower.profileImageURL %>" 
                                                 width="60" height="60" 
                                                 class="rounded-circle mb-2"
                                                 onerror="this.src='/imgs/default.png';">
                                            <h6 class="fw-bold"><%= follower.fullName %></h6>
                                            <p class="text-muted small"><%= follower.email %></p>
                                            <div class="d-flex gap-2">
                                                <a href="/user/profile/<%= follower._id %>" class="btn btn-sm btn-outline-primary flex-grow-1">
                                                    <i class="fas fa-eye"></i> View Profile
                                                </a>
                                                <% if (currentUserId && currentUserId != follower._id) { %>
                                                    <button class="btn btn-sm btn-outline-primary" 
                                                            onclick="toggleFollow('<%= follower._id %>', this)"
                                                            data-following="false">
                                                        <i class="fas fa-user-plus"></i>
                                                    </button>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } %>
                    </div>
                <% } %>
            </div>

            <!-- Following Tab -->
            <div class="tab-pane fade" id="following" role="tabpanel">
                <% if (user.following && user.following.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="fas fa-heart fa-5x text-muted mb-3"></i>
                        <p class="text-muted">Not following anyone yet</p>
                    </div>
                <% } else { %>
                    <div class="row">
                        <% if (user.following) { %>
                            <% user.following.forEach(followee => { %>
                                <div class="col-md-6 col-lg-4 mb-3">
                                    <div class="card">
                                        <div class="card-body text-center">
                                            <img src="<%= followee.profileImageURL %>" 
                                                 width="60" height="60" 
                                                 class="rounded-circle mb-2"
                                                 onerror="this.src='/imgs/default.png';">
                                            <h6 class="fw-bold"><%= followee.fullName %></h6>
                                            <p class="text-muted small"><%= followee.email %></p>
                                            <div class="d-flex gap-2">
                                                <a href="/user/profile/<%= followee._id %>" class="btn btn-sm btn-primary flex-grow-1">
                                                    <i class="fas fa-eye"></i> View Profile
                                                </a>
                                                <% if (currentUserId && currentUserId != followee._id) { %>
                                                    <button class="btn btn-sm btn-success" 
                                                            onclick="toggleFollow('<%= followee._id %>', this)"
                                                            data-following="true">
                                                        <i class="fas fa-user-check"></i>
                                                    </button>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } %>
                    </div>
                <% } %>
            </div>

            <!-- Analytics Tab (Only for own profile) -->
            <% if (isOwnProfile) { %>
                <div class="tab-pane fade" id="analytics" role="tabpanel">
                    <div class="row">
                        <div class="col-md-6 col-lg-3 mb-3">
                            <div class="card text-center">
                                <div class="card-body">
                                    <i class="fas fa-book fa-3x text-primary mb-3"></i>
                                    <h6 class="text-muted">Total Blogs</h6>
                                    <h3 class="fw-bold" id="totalBlogs">0</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3 mb-3">
                            <div class="card text-center">
                                <div class="card-body">
                                    <i class="fas fa-eye fa-3x text-success mb-3"></i>
                                    <h6 class="text-muted">Total Views</h6>
                                    <h3 class="fw-bold" id="totalViews">0</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3 mb-3">
                            <div class="card text-center">
                                <div class="card-body">
                                    <i class="fas fa-heart fa-3x text-danger mb-3"></i>
                                    <h6 class="text-muted">Total Likes</h6>
                                    <h3 class="fw-bold" id="totalLikes">0</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3 mb-3">
                            <div class="card text-center">
                                <div class="card-body">
                                    <i class="fas fa-comment fa-3x text-info mb-3"></i>
                                    <h6 class="text-muted">Total Comments</h6>
                                    <h3 class="fw-bold" id="totalComments">0</h3>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <%- include("./partials/scripts") %>

    <script>
        const userId = '<%= user._id %>';
        const currentUserId = '<%= currentUserId || "" %>';
        const isOwnProfile = <%= isOwnProfile %>;

        // Delete Blog
        async function deleteBlog(id, event) {
            event.preventDefault();
            if (!await confirmAction('Are you sure you want to delete this blog?')) return;

            try {
                const res = await axios.delete(`/blogs/${id}`);
                if (res.data.success) {
                    notify.success('Blog deleted successfully!');
                    setTimeout(() => location.reload(), 1500);
                }
            } catch (err) {
                notify.error('Failed to delete blog');
            }
        }

        // Toggle Follow - Now works from profile page
        async function toggleFollow(targetUserId, buttonElement) {
            if (!currentUserId) {
                window.location.href = '/user/signin';
                return;
            }

            if (targetUserId === currentUserId) {
                notify.warning('You cannot follow yourself');
                return;
            }

            const originalHTML = buttonElement.innerHTML;
            const originalClass = buttonElement.className;
            buttonElement.disabled = true;

            try {
                const res = await axios.post(`/follow/${targetUserId}/follow`);
                const data = res.data;

                if (data.success) {
                    if (data.following) {
                        buttonElement.innerHTML = `<i class="fas fa-user-check"></i> Following`;
                        buttonElement.classList.remove('btn-outline-primary');
                        buttonElement.classList.add('btn-success');
                        buttonElement.dataset.following = 'true';
                    } else {
                        buttonElement.innerHTML = `<i class="fas fa-user-plus"></i> Follow`;
                        buttonElement.classList.remove('btn-success');
                        buttonElement.classList.add('btn-outline-primary');
                        buttonElement.dataset.following = 'false';
                    }
                    notify.success(data.message);
                } else {
                    notify.error(data.message || 'Action failed');
                }
            } catch (err) {
                console.error("Follow Error:", err);
                notify.error(err.response?.data?.message || 'Failed to follow user');
            } finally {
                buttonElement.disabled = false;
            }
        }

        // Load Analytics (only on own profile)
        <% if (isOwnProfile) { %>
            async function loadAnalytics() {
                try {
                    const res = await axios.get('/analytics/author/stats');
                    if (res.data.success) {
                        const stats = res.data.stats;
                        document.getElementById('totalBlogs').textContent = stats.totalBlogs;
                        document.getElementById('totalViews').textContent = stats.totalViews;
                        document.getElementById('totalLikes').textContent = stats.totalLikes;
                        document.getElementById('totalComments').textContent = stats.totalComments;
                    }
                } catch (err) {
                    console.error('Error loading analytics:', err);
                }
            }

            const analyticsTab = document.getElementById('analytics-tab');
            if (analyticsTab) {
                analyticsTab.addEventListener('shown.bs.tab', loadAnalytics);
            }
        <% } %>

        // Edit Profile Button
        const editBtn = document.getElementById('editProfileBtn');
        if (editBtn) {
            editBtn.addEventListener('click', () => {
                if (!isOwnProfile) {
                    notify.warning('You can only edit your own profile');
                    return;
                }
                window.location.href = '/user/profile/edit';
            });
        }
    </script>
</body>
</html>
