<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Sign Up - Blogify</title>
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .auth-card {
            background: rgba(255, 255, 255, 0.97);
            backdrop-filter: blur(12px);
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
            overflow: hidden;
        }

        .form-control {
            border-radius: 12px;
            padding: 12px 16px;           /* Reduced padding */
            border: 2px solid #e2e8f0;
            transition: all 0.3s ease;
            font-size: 0.98rem;
        }

        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.15);
        }

        /* OTP Styling */
        .otp-box {
            width: 46px;
            height: 54px;
            font-size: 1.45rem;
            font-weight: 600;
            text-align: center;
            border-radius: 10px;
            border: 2px solid #e2e8f0;
        }

        .otp-box:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.15);
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea, #5a67d8);
            border: none;
            border-radius: 12px;
            padding: 13px;
            font-weight: 600;
            font-size: 1.02rem;
        }

        .google-btn {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 13px;
            font-weight: 500;
        }

        .divider {
            display: flex;
            align-items: center;
            color: #94a3b8;
            margin: 20px 0;
        }
        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e2e8f0;
        }

        /* Smaller overall form */
        .auth-card {
            max-width: 420px;
            margin: 0 auto;
        }

        /* Mobile Optimizations */
        @media (max-width: 576px) {
            .auth-card {
                margin: 12px;
                border-radius: 16px;
                padding: 1.5rem !important;
            }
            .otp-box {
                width: 40px;
                height: 50px;
                font-size: 1.35rem;
            }
        }
    </style>
</head>
<body class="d-flex align-items-center">
    <%- include("./partials/nave") %>

    <div class="container py-4 py-md-5">
        <div class="row justify-content-center">
            <div class="col-11 col-sm-10 col-md-6 col-lg-5">   <!-- Reduced width -->
                <div class="auth-card p-4 p-sm-5">               <!-- Reduced padding -->
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-dark mb-1">Create Account</h2>
                        <p class="text-muted small">Join Blogify and start sharing</p>
                    </div>

                    <!-- Google Signup -->
                    <a href="/user/auth/google" 
                       class="google-btn d-flex align-items-center justify-content-center gap-3 w-100 text-decoration-none text-dark mb-4">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" 
                             width="22" height="22" alt="Google">
                        Sign up with Google
                    </a>

                    <div class="divider">
                        <span>OR</span>
                    </div>

                    <form id="signupForm">
                        <div class="mb-3">
                            <label class="form-label fw-medium">Full Name</label>
                            <input type="text" id="fullName" name="fullName" class="form-control" placeholder="John Doe" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-medium">Email Address</label>
                            <input type="email" id="email" name="email" class="form-control" placeholder="you@example.com" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-medium">Password</label>
                            <div class="input-group">
                                <input type="password" id="password" name="password" class="form-control" required>
                                <button type="button" class="btn btn-outline-secondary" id="togglePassword" 
                                        style="border-radius: 0 12px 12px 0; min-width: 48px;">
                                    👁️
                                </button>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-medium">Verification Code (OTP)</label>
                            <div class="d-flex gap-2 justify-content-center mb-3" id="otpContainer">
                                <input type="text" maxlength="1" class="otp-box form-control text-center" data-index="0">
                                <input type="text" maxlength="1" class="otp-box form-control text-center" data-index="1">
                                <input type="text" maxlength="1" class="otp-box form-control text-center" data-index="2">
                                <input type="text" maxlength="1" class="otp-box form-control text-center" data-index="3">
                                <input type="text" maxlength="1" class="otp-box form-control text-center" data-index="4">
                                <input type="text" maxlength="1" class="otp-box form-control text-center" data-index="5">
                            </div>
                            <button type="button" class="btn btn-primary w-100 send-otp-btn" id="sendOtpBtn">
                                Send OTP
                            </button>
                            <input type="hidden" name="otp" id="hiddenOtp">
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3" id="submitBtn">
                            Create Account
                        </button>
                    </form>

                    <p class="text-center mt-4 mb-0">
                        Already have an account? 
                        <a href="/user/signin" class="text-primary fw-medium">Sign In</a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <%- include("./partials/scripts") %>

    <script>
        // Password Toggle
        document.getElementById('togglePassword').addEventListener('click', function () {
            const pw = document.getElementById('password');
            if (pw.type === 'password') {
                pw.type = 'text';
                this.textContent = '🙈';
            } else {
                pw.type = 'password';
                this.textContent = '👁️';
            }
        });

        // OTP Handling
        const otpInputs = document.querySelectorAll('.otp-box');
        otpInputs.forEach((input, index) => {
            input.addEventListener('input', () => {
                if (input.value.length === 1 && index < 5) {
                    otpInputs[index + 1].focus();
                }
                updateHiddenOtp();
            });

            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && input.value === '' && index > 0) {
                    otpInputs[index - 1].focus();
                }
            });
        });

        function updateHiddenOtp() {
            let otp = '';
            otpInputs.forEach(box => otp += box.value);
            document.getElementById('hiddenOtp').value = otp;
        }

        // Send OTP
        document.getElementById('sendOtpBtn').addEventListener('click', async function() {
            const email = document.getElementById('email').value.trim();
            if (!email) return alert("Please enter your email first!");

            this.disabled = true;
            this.textContent = "Sending OTP...";

            try {
                const res = await fetch('/user/send-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });

                const data = await res.json();

                if (data.success) {
                    alert(`✅ OTP sent to ${email}`);
                    this.textContent = "Resend OTP";
                    setTimeout(() => this.disabled = false, 30000);
                } else {
                    alert(data.message || "Failed to send OTP");
                    this.disabled = false;
                    this.textContent = "Send OTP";
                }
            } catch (err) {
                alert("Failed to send OTP");
                this.disabled = false;
                this.textContent = "Send OTP";
            }
        });

        // Signup Form Submit
        document.getElementById('signupForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Creating...`;

            const formData = new FormData(this);
            const data = Object.fromEntries(formData.entries());

            try {
                const res = await fetch('/user/signup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await res.json();

                if (result.success) {
                    alert("🎉 Account created successfully!");
                    window.location.href = "/";
                } else {
                    alert(result.message);
                    submitBtn.disabled = false;
                    submitBtn.textContent = "Create Account";
                }
            } catch (err) {
                alert("Something went wrong");
                submitBtn.disabled = false;
                submitBtn.textContent = "Create Account";
            }
        });
    </script>
</body>
</html>
