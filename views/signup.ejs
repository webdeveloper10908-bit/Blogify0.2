<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Blogify</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .signup-container {
            background: white;
            padding: 40px 30px;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 420px;
        }

        h2 {
            text-align: center;
            color: #1a1a1a;
            margin-bottom: 24px;
            font-size: 28px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: #555;
            font-weight: 500;
        }

        input[type="text"],
        input[type="email"],
        input[type="password"] {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid #e5e7eb;
            border-radius: 10px;
            font-size: 16px;
            transition: all 0.3s;
        }

        input:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        button[type="submit"] {
            width: 100%;
            padding: 14px;
            background: #667eea;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
        }

        button[type="submit"]:hover {
            background: #5568d3;
        }

        button[type="submit"]:disabled {
            background: #a5b4fc;
            cursor: not-allowed;
        }

        .google-btn {
            width: 100%;
            padding: 14px;
            background: white;
            color: #333;
            border: 2px solid #e5e7eb;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 15px;
            text-decoration: none;
        }

        .google-btn:hover {
            background: #f8f9fa;
            border-color: #667eea;
        }

        .divider {
            text-align: center;
            margin: 24px 0;
            color: #9ca3af;
            position: relative;
        }

        .divider::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 1px;
            background: #e5e7eb;
        }

        .divider span {
            background: white;
            padding: 0 15px;
        }

        /* Message banners for general alerts */
        .alert {
            padding: 12px;
            border-radius: 8px;
            text-align: center;
            margin-bottom: 15px;
            display: none;
        }

        .alert-success {
            color: #10b981;
            background: #d1fae5;
        }

        .alert-error {
            color: #ef4444;
            background: #fee2e2;
        }

        /* Modal Styles */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(5px);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal {
            background: white;
            padding: 32px 24px;
            border-radius: 20px;
            box-shadow: 0 25px 80px rgba(0,0,0,0.4);
            width: 100%;
            max-width: 400px;
            text-align: center;
        }

        .btn-close {
            position: absolute;
            top: 12px;
            right: 12px;
            font-size: 28px;
            background: none;
            border: none;
            cursor: pointer;
            color: #6b7280;
        }

        .modal-icon { font-size: 48px; margin-bottom: 12px; }
        .modal h3 { color: #1a1a1a; margin-bottom: 8px; }
        .modal p { color: #6b7280; margin-bottom: 24px; }

        .otp-inputs {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-bottom: 24px;
        }

        .otp-digit {
            width: 45px;
            height: 50px;
            text-align: center;
            font-size: 22px;
            font-weight: bold;
            border: 2px solid #e5e7eb;
            border-radius: 10px;
        }

        .otp-digit:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.2);
            outline: none;
        }

        .btn-verify {
            width: 100%;
            padding: 14px;
            background: #667eea;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-bottom: 12px;
        }

        .btn-verify:hover {
            background: #5568d3;
        }

        .btn-resend {
            background: none;
            border: none;
            color: #667eea;
            font-size: 15px;
            cursor: pointer;
        }

        .btn-resend:disabled {
            color: #9ca3af;
            cursor: not-allowed;
        }

        .timer { color: #9ca3af; font-size: 14px; margin-top: 8px; }
        .error-message { color: #ef4444; margin: 12px 0; min-height: 20px; font-weight: 500; }
    </style>
</head>
<body>

    <div class="signup-container">
        <h2>Create Account</h2>

        <!-- Dynamically handled message slots -->
        <div id="statusAlert" class="alert"></div>

        <form id="signupForm">
            <div class="form-group">
                <label for="fullName">Full Name</label>
                <input type="text" id="fullName" name="fullName" required placeholder="Enter your full name">
            </div>
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" required placeholder="Enter your email">
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required placeholder="Create password">
            </div>
            <div class="form-group">
                <label for="confirmPassword">Confirm Password</label>
                <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="Confirm password">
            </div>
            <button type="submit" id="signupSubmitBtn">Sign Up</button>
        </form>

        <div class="divider"><span>OR</span></div>

        <a href="/user/auth/google" class="google-btn">
            <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" 
                 alt="Google" width="20" height="20">
            Continue with Google
        </a>
    </div>

    <!-- OTP Modal -->
    <div class="modal-overlay" id="otpModal">
        <div class="modal" style="position: relative;">
            <button class="btn-close" onclick="closeModal()">×</button>
            
            <div class="modal-icon">🔐</div>
            <h3>Verify Your Email</h3>
            <p>We've sent a 6-digit code to <strong id="displayEmail"></strong></p>
            
            <div class="otp-inputs">
                <input type="text" maxlength="1" class="otp-digit" data-index="0">
                <input type="text" maxlength="1" class="otp-digit" data-index="1">
                <input type="text" maxlength="1" class="otp-digit" data-index="2">
                <input type="text" maxlength="1" class="otp-digit" data-index="3">
                <input type="text" maxlength="1" class="otp-digit" data-index="4">
                <input type="text" maxlength="1" class="otp-digit" data-index="5">
            </div>
            
            <div class="error-message" id="otpError"></div>
            
            <button class="btn-verify" onclick="verifyOTP()">Verify OTP</button>
            <button class="btn-resend" id="resendBtn" onclick="resendOTP()" disabled>Resend Code</button>
            <div class="timer" id="timer"></div>
        </div>
    </div>

    <script>
        const signupForm = document.getElementById('signupForm');
        const signupSubmitBtn = document.getElementById('signupSubmitBtn');
        const statusAlert = document.getElementById('statusAlert');
        
        const modal = document.getElementById('otpModal');
        const displayEmail = document.getElementById('displayEmail');
        const otpInputs = document.querySelectorAll('.otp-digit');
        const otpError = document.getElementById('otpError');
        
        let currentEmail = "";
        let countdown = 300; // 5 minutes
        let timerInterval;

        // Helper to display page alerts
        function showAlert(message, type = 'error') {
            statusAlert.textContent = message;
            statusAlert.className = `alert alert-${type}`;
            statusAlert.style.display = 'block';
        }

        function hideAlert() {
            statusAlert.style.display = 'none';
        }

        // ==========================================
        // 1. ASYNC SIGNUP SUBMISSION
        // ==========================================
        signupForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            hideAlert();

            const fullName = document.getElementById('fullName').value;
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const confirmPassword = document.getElementById('confirmPassword').value;

            if (password !== confirmPassword) {
                showAlert("Passwords do not match");
                return;
            }

            signupSubmitBtn.disabled = true;
            signupSubmitBtn.textContent = "Sending OTP...";

            try {
                // We point exactly to your route setup
                const res = await fetch('/user/signup', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ fullName, email, password, confirmPassword })
                });

                const contentType = res.headers.get("content-type");
                
                // If the response is HTML, your route failed validation and re-rendered the full page
                if (contentType && contentType.includes("text/html")) {
                    signupSubmitBtn.disabled = false;
                    signupSubmitBtn.textContent = "Sign Up";
                    showAlert("Registration error. Check fields or try another email.");
                    return;
                }

                // If your backend responds with successful validation data
                currentEmail = email.toLowerCase();
                displayEmail.textContent = currentEmail;
                
                // Reset inputs inside modal
                otpInputs.forEach(input => input.value = '');
                otpError.textContent = '';
                
                // Display the modal popup cleanly
                modal.classList.add('active');
                otpInputs[0].focus();
                startTimer();

            } catch (err) {
                console.error("Signup Submission Error:", err);
                showAlert("Something went wrong. Please check your connection.");
            } finally {
                signupSubmitBtn.disabled = false;
                signupSubmitBtn.textContent = "Sign Up";
            }
        });

        // ==========================================
        // 2. 6-BOX INTERACTION LOGIC
        // ==========================================
        otpInputs.forEach((input, index) => {
            // Numbers typing processing
            input.addEventListener('input', (e) => {
                input.value = input.value.replace(/[^0-9]/g, ''); // Numeric filter
                if (input.value.length === 1 && index < 5) {
                    otpInputs[index + 1].focus();
                }
            });

            // Backspace alignment tracking
            input.addEventListener('keydown', (e) => {
                if (e.key === "Backspace" && input.value === "" && index > 0) {
                    otpInputs[index - 1].focus();
                }
            });

            // Clean clipboard parsing support for fast copy-pasting
            input.addEventListener('paste', (e) => {
                e.preventDefault();
                const pasteData = e.clipboardData.getData('text').trim();
                if (/^\d{6}$/.test(pasteData)) {
                    otpInputs.forEach((inp, idx) => {
                        inp.value = pasteData[idx];
                    });
                    otpInputs[5].focus();
                }
            });
        });

        // ==========================================
        // 3. COUNTDOWN TIMER SYSTEM
        // ==========================================
        function startTimer() {
            clearInterval(timerInterval);
            countdown = 300; // 5 mins
            document.getElementById('resendBtn').disabled = true;

            timerInterval = setInterval(() => {
                const min = Math.floor(countdown / 60);
                const sec = countdown % 60;
                document.getElementById('timer').textContent = `Expires in ${min}:${sec < 10 ? '0' : ''}${sec}`;
                countdown--;

                if (countdown < 0) {
                    clearInterval(timerInterval);
                    document.getElementById('resendBtn').disabled = false;
                    document.getElementById('timer').textContent = 'OTP Expired.';
                }
            }, 1000);
        }

        // ==========================================
        // 4. VERIFY OTP SUBMISSION
        // ==========================================
        async function verifyOTP() {
            otpError.textContent = "";
            const otp = Array.from(otpInputs).map(i => i.value).join('');
            
            if (otp.length !== 6) {
                otpError.textContent = "Please enter all 6 digits";
                return;
            }

            try {
                const res = await fetch('/user/verify-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: currentEmail, otp })
                });

                const data = await res.json();

                if (data.success) {
                    closeModal();
                    alert("✅ Account created and verified successfully!");
                    window.location.href = "/"; // Directs to home layout
                } else {
                    otpError.textContent = data.message || "Invalid OTP";
                }
            } catch (err) {
                otpError.textContent = "Verification failed. Check network settings.";
            }
        }

        function closeModal() {
            modal.classList.remove('active');
            clearInterval(timerInterval);
        }

        async function resendOTP() {
            alert("Resending validation code to your email...");
            closeModal();
            signupForm.dispatchEvent(new Event('submit'));
        }
    </script>
</body>
</html>
